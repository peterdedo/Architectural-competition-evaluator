# Zkopírujte na .env nebo .env.local v kořenu projektu (soubory jsou v .gitignore).
# Po změně restartujte `npm run dev`, aby openai-proxy znovu načetl proměnné.
# Podrobnosti: README.md → sekce „Lokální OpenAI proxy (vývoj)“.
#
# DŮLEŽITÉ: lokální server/openai-proxy.mjs čte jen OPENAI_API_KEY (ne VITE_OPENAI_KEY).

OPENAI_API_KEY=sk-váš-klíč-z-platform.openai.com

# Volitelné: port lokálního proxy (výchozí 8792; Vite čte stejnou proměnnou z .env přes vite.config.js)
# OPENAI_PROXY_PORT=8792

# Volitelné: absolutní základ URL pro /api/openai (prázdné = relativní cesty)
# VITE_API_BASE_URL=

# Pouze nasazení na Vercel: povolit GET /api/openai/models (ve výchozím stavu serverless endpoint odmítne – menší riziko zneužití klíče)
# OPENAI_ALLOW_MODELS_LIST=true

# Volitelné: max. velikost JSON těla pro POST /api/openai/chat (bajty, výchozí 10 MiB, strop 50 MiB) – lokálně i Vercel
# OPENAI_CHAT_MAX_BODY_BYTES=10485760

# Volitelné: povolené modely pro POST /api/openai/chat (čárkou oddělené ID, přesná shoda; prázdné = gpt-4o,gpt-4o-mini)
# OPENAI_CHAT_ALLOWED_MODELS=gpt-4o,gpt-4o-mini
